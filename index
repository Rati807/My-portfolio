<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Rati Portfolio</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <!-- Google Font -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;600&display=swap" rel="stylesheet">

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: 'Poppins', sans-serif;
    }

    body {
      display: flex;
      background: #0f172a;
      color: white;
    }

    .left {
      width: 30%;
      height: 100vh;
      background: linear-gradient(180deg, #1e293b, #020617);
      text-align: center;
      padding: 30px;
      position: fixed;
    }

    .left img {
      width: 150px;
      height: 150px;
      border-radius: 50%;
      border: 4px solid #38bdf8;
      box-shadow: 0 0 20px #38bdf8;
      margin-bottom: 15px;
    }

    .left h2 {
      margin-bottom: 5px;
    }

    .left p {
      color: #94a3b8;
    }

    .socials a {
      display: inline-block;
      margin: 10px;
      color: #38bdf8;
      text-decoration: none;
    }

    .right {
      margin-left: 30%;
      width: 70%;
      padding: 40px;
    }

    section {
      margin-bottom: 50px;
    }

    h1 {
      margin-bottom: 10px;
      color: #38bdf8;
    }

    .btn {
      display: inline-block;
      padding: 10px 20px;
      margin-top: 10px;
      background: #38bdf8;
      color: black;
      border-radius: 5px;
      text-decoration: none;
      transition: 0.3s;
    }

    .btn:hover {
      background: white;
    }

    .projects {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
      gap: 20px;
    }

    .card {
      background: #1e293b;
      padding: 20px;
      border-radius: 10px;
      transition: 0.3s;
    }

    .card:hover {
      transform: translateY(-10px);
      box-shadow: 0 0 20px #38bdf8;
    }

    .skills span {
      display: inline-block;
      background: #334155;
      padding: 8px 12px;
      margin: 5px;
      border-radius: 5px;
    }

  </style>
</head>

<body>

  <!-- LEFT SIDE -->
  <div class="left">
    <img src="c:\Users\Advance Laptop\Desktop\photo 1.jpeg" alt="Rati">
    <h2>Rati</h2>
    <p>BCA Student | Web Developer</p>

    <div class="socials">
      <a href="#">GitHub</a>
      <a href="#">LinkedIn</a>
      <a href="#">Instagram</a>
    </div>
  </div>

  <!-- RIGHT SIDE -->
  <div class="right">

    <section>
      <h1>About Me</h1>
      <p>
        Hi, I'm Rati 👋  
        I am a BCA student passionate about web development.  
        I create modern and user-friendly websites.
      </p>
      <a href="#" class="btn">Hire Me</a>
    </section>

    <section>
      <h1>Skills</h1>
      <div class="skills">
        <span>HTML</span>
        <span>CSS</span>
        <span>JavaScript</span>
        <span>GitHub</span>
      </div>
    </section>

    <section>
      <h1>Projects</h1>
      <div class="projects">
        <div class="card">
          <h3>EduTrack</h3>
          <p>Coding contest platform with dashboard UI.</p>
          <a href="#" class="btn">View</a>
        </div>

        <div class="card">
          <h3>Portfolio Website</h3>
          <p>Personal portfolio with modern design.</p>
          <a href="#" class="btn">View</a>
        </div>
      </div>
    </section>

    <section>
      <h1>Contact</h1>
      <p>Email: rati11532@email.com</p>
    </section>

  </div>

</body>
</html>